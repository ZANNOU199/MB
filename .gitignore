# Global ignores
.DS_Store
Thumbs.db

# Node.js / React
node_modules/
build/
dist/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Laravel
vendor/
storage/
bootstrap/cache/
.env
.env.*
.phpunit.result.cache
/.phpunit.result.cache

# Logs
*.log
*.log.*

# IDEs and editors
.vscode/
.idea/
*.sublime-workspace
*.sublime-project
.history/

# OS generated files
*.swp
*.tmp
ehthumbs.db
Desktop.ini

# Misc
coverage/
coverage-*
*.tgz
*.gz

# Frontend build outputs
MB-PREMIUM-LIVING/build/
MB-PREMIUM-LIVING/dist/

# Backend build outputs
apimb/vendor/
apimb/storage/
apimb/bootstrap/cache/
apimb/.env
apimb/.env.*

# Prevent accidental repo-in-repo
.gitmodules

# Prevent sensitive files
apimb/.env.local
apimb/.env.production
apimb/.env.development
MB-PREMIUM-LIVING/.env
MB-PREMIUM-LIVING/.env.*

# Prevent lock files (optional, if not needed)
# package-lock.json
yarn.lock
pnpm-lock.yaml
